# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API Keys (server-side only)
DEEPGRAM_API_KEY=your-deepgram-key
ANTHROPIC_API_KEY=your-anthropic-key
RESEND_API_KEY=your-resend-key
# Optional: override sender address (must be a verified Resend domain; defaults to noreply@debrief.whitecoatprep.com)
# In dev/pilot you can use Resend's sandbox address: onboarding@resend.dev
RESEND_FROM_EMAIL=
# Optional: BCC all assessment notifications to a program administrator
# Must be a valid email address. Leave blank to disable admin notifications.
PROGRAM_ADMIN_EMAIL=
# Dev-only: bypass auth middleware for local testing. NEVER set to true in production.
# Use a non-NEXT_PUBLIC_ name to prevent this value from leaking into the client bundle.
DEV_BYPASS_AUTH=

# ── Gemini / Vertex AI (PHIPA/PIPEDA compliance — PHI stays in Canada) ───────
#
# Provider selection:
#   STT_PROVIDER=gemini   → Vertex AI Gemini 2.5 Flash in northamerica-northeast1 (Montreal)
#   STT_PROVIDER=deepgram → legacy Deepgram + Anthropic path (kept for rollback)
#   (unset)               → auto-detects: gemini if GOOGLE_APPLICATION_CREDENTIALS is set,
#                           else deepgram.
#
# To use Gemini:
#   1. Create a GCP service account with roles/aiplatform.user in your project.
#   2. Download the JSON key and set GOOGLE_APPLICATION_CREDENTIALS to its path.
#   3. Set GCP_PROJECT_ID to your GCP project ID.
#   4. Ensure Vertex AI API is enabled and Gemini 2.5 Flash is available in
#      northamerica-northeast1 (https://cloud.google.com/vertex-ai/docs/regions).
#   5. On Vercel: upload the service-account JSON as a secret and set
#      GOOGLE_APPLICATION_CREDENTIALS to the file path (or use Workload Identity
#      Federation if deploying on GCP infrastructure).
STT_PROVIDER=gemini
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
