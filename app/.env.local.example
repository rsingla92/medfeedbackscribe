# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API Keys (server-side only)
DEEPGRAM_API_KEY=your-deepgram-key
ANTHROPIC_API_KEY=your-anthropic-key
RESEND_API_KEY=your-resend-key
# Optional: override sender address (must be a verified Resend domain; defaults to noreply@debrief.whitecoatprep.com)
# In dev/pilot you can use Resend's sandbox address: onboarding@resend.dev
RESEND_FROM_EMAIL=
# Optional: BCC all assessment notifications to a program administrator
# Must be a valid email address. Leave blank to disable admin notifications.
PROGRAM_ADMIN_EMAIL=
# Dev-only: bypass auth middleware for local testing. NEVER set to true in production.
# Use a non-NEXT_PUBLIC_ name to prevent this value from leaking into the client bundle.
DEV_BYPASS_AUTH=
