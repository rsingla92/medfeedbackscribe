# ── Container / App Runner runtime ─────────────────────────────────────────
# Absolute URL used for SSR callbacks and email links. In the container,
# App Runner injects the public service URL here.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# App Runner convention — the platform forwards traffic to $PORT.
PORT=3000
# Required for Next.js standalone output to bind on all interfaces inside
# the container (loopback-only would make App Runner health checks fail).
HOSTNAME=0.0.0.0

# ── Auth.js (magic link + Google OAuth) ────────────────────────────────────
# AUTH_SECRET: 32+ random bytes, base64. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=
# AUTH_URL: public origin for this deployment (e.g. https://debrief.example.com).
# REQUIRED in production — the app throws at module load if NODE_ENV=production
# and AUTH_URL is unset. Pinning AUTH_URL is what prevents host-header spoofing
# on magic-link emails (attacker sends Host: evil.com → email link points at
# evil.com → token exfiltrated on click). Must be an absolute URL with scheme.
AUTH_URL=http://localhost:3000
# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SES (transactional email — magic link + assessment notifications) ──────
# SES identity must be verified for this from-address. Defaults to
# noreply@debrief.whitecoatprep.com. SES runs in ca-central-1 (residency).
SES_FROM_EMAIL=
# Optional: BCC all assessment notifications to a program administrator.
PROGRAM_ADMIN_EMAIL=

# Dev-only: bypass auth middleware for local testing. NEVER set to true in
# production. DEV_BYPASS_AUTH=true is ignored unless NODE_ENV=development
# (explicit positive match — unset NODE_ENV fails closed).
DEV_BYPASS_AUTH=

# ── Postgres (RDS in prod, local pg for dev) ───────────────────────────────
# In production, App Runner injects DATABASE_URL from Secrets Manager.
# Locally, run `docker compose up postgres` or point at any Postgres ≥ 14.
DATABASE_URL=postgresql://debrief:debrief@localhost:5432/debrief

# ── Vertex AI (PHI pipeline — Montreal region, PHIPA residency) ────────────
# Only needed by the Lambda, not the Next.js app. Kept here so the same
# .env.local.example covers both sides of the codebase.
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── AWS S3 + SQS (storage + pipeline) ──────────────────────────────────────
# Values come from CDK outputs after `cdk deploy`.
S3_RECORDINGS_BUCKET=debrief-recordings-687591846902-ca-central-1
AWS_REGION=ca-central-1
# Pipeline SQS queue — used by /api/reprocess to re-enqueue stalled sessions.
SQS_PIPELINE_QUEUE_URL=
