# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email (optional — assessments still work without it)
RESEND_API_KEY=your-resend-key
# Optional: override sender address (must be a verified Resend domain; defaults to noreply@debrief.whitecoatprep.com)
# In dev/pilot you can use Resend's sandbox address: onboarding@resend.dev
RESEND_FROM_EMAIL=
# Optional: BCC all assessment notifications to a program administrator
# Must be a valid email address. Leave blank to disable admin notifications.
PROGRAM_ADMIN_EMAIL=
# Dev-only: bypass auth middleware for local testing. NEVER set to true in production.
# Use a non-NEXT_PUBLIC_ name to prevent this value from leaking into the client bundle.
DEV_BYPASS_AUTH=

# ── Gemini / Vertex AI (PHIPA/PIPEDA compliance — PHI stays in Canada) ───────
#
# All STT, PHI scrubbing, and assessment extraction runs via Vertex AI in
# northamerica-northeast1 (Montreal). No Deepgram or Anthropic keys needed.
#
# Setup:
#   1. Create a GCP project and enable the Vertex AI API.
#   2. Create a service account with roles/aiplatform.user.
#   3. Download the JSON key file.
#   4. Set GOOGLE_APPLICATION_CREDENTIALS to the absolute path of that key file.
#   5. Set GCP_PROJECT_ID to your GCP project ID.
#   6. Confirm Gemini 2.5 Flash is available in northamerica-northeast1:
#      https://cloud.google.com/vertex-ai/docs/regions
#
# On Vercel:
#   - Upload the service-account JSON as a Vercel secret (encrypted at rest).
#   - Set GOOGLE_APPLICATION_CREDENTIALS to the path where it is written at runtime,
#     or use Workload Identity Federation if deploying on GCP infrastructure.
#
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
